<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>股票庫存績效報表</title>
  <style>
    :root {
      --bg: #ffffff;
      --bg-2: #f7f9fc;
      --panel: rgba(247, 249, 252, 0.94);
      --panel-strong: rgba(255, 255, 255, 0.98);
      --line: rgba(30, 35, 41, 0.10);
      --line-strong: rgba(30, 35, 41, 0.16);
      --text: #1e2329;
      --heading: #1e2329;
      --muted: #66717f;
      --soft: #1e2329;
      --dim: #8d98a7;
      --accent: #704214;
      --accent-2: #5e5adb;
      --glow: rgba(94, 90, 219, 0.10);
      --shadow: 0 10px 30px rgba(30, 35, 41, 0.06);
      --red: #d83f56;
      --green: #0f9f72;
      --orange: #704214;
      --radius: 8px;
      --transition: 180ms ease;
    }
    * { box-sizing: border-box; }
    html { background: var(--bg); }
    body {
      margin: 0;
      color: var(--soft);
      font-family: Inter, Roboto, "SF Pro Text", "Helvetica Neue", Arial, "Microsoft JhengHei", sans-serif;
      font-size: 14px;
      background: linear-gradient(180deg, var(--bg) 0%, var(--bg-2) 100%);
      min-height: 100vh;
    }
    .shell {
      max-width: 1440px;
      margin: 0 auto;
      padding: 28px 20px 56px;
    }
    .hero,
    .panel,
    .card,
    .mini-stat {
      border: 1px solid var(--line);
      background: linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, var(--panel) 100%);
      box-shadow: var(--shadow);
      transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition), background-color var(--transition);
    }
    .eyebrow,
    .panel-kicker,
    .mini-label,
    .label,
    .table-caption {
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-size: 10px;
    }
    .eyebrow,
    .panel-kicker,
    .mini-label,
    .label,
    .table-caption,
    .muted {
      color: var(--dim);
    }
    .main {
      min-width: 0;
    }
    .hero {
      position: relative;
      overflow: hidden;
      border-radius: var(--radius);
      padding: 20px 22px;
      margin-bottom: 20px;
    }
    .hero::after {
      content: "";
      position: absolute;
      inset: auto -20px -70px auto;
      width: 220px;
      height: 220px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(94, 90, 219, 0.10), transparent 68%);
      filter: blur(14px);
    }
    .hero-grid {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: minmax(0, 1.6fr) minmax(280px, 0.8fr);
      gap: 18px;
      align-items: end;
    }
    .hero h1 {
      margin: 10px 0 10px;
      font-size: 24px;
      line-height: 1.12;
      letter-spacing: 0.02em;
      color: var(--accent);
    }
    .hero p {
      margin: 0;
      max-width: 720px;
      color: var(--dim);
      font-size: 13px;
      line-height: 1.6;
    }
    .hero-stats {
      display: grid;
      gap: 12px;
    }
    .mini-stat {
      border-radius: var(--radius);
      padding: 12px 14px;
      background: rgba(247, 249, 252, 0.92);
    }
    .mini-value {
      margin-top: 8px;
      font-size: 22px;
      font-weight: 700;
      color: var(--accent-2);
    }
    .mini-note {
      margin-top: 6px;
      color: var(--dim);
      font-size: 11px;
    }
    .section-title {
      margin: 0 0 14px;
      font-size: 18px;
      letter-spacing: 0.03em;
      color: var(--heading);
    }
    .stack {
      display: grid;
      gap: 18px;
    }
    .panel {
      border-radius: var(--radius);
      padding: 18px;
      overflow: hidden;
    }
    .panel-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 16px;
    }
    .panel-head p {
      margin: 6px 0 0;
      color: var(--dim);
      font-size: 12px;
    }
    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 10px;
    }
    .currency-block + .currency-block {
      margin-top: 18px;
    }
    .market-label {
      display: inline-flex;
      margin-bottom: 12px;
      padding: 6px 10px;
      border: 1px solid var(--line-strong);
      background: rgba(94, 90, 219, 0.06);
      color: var(--accent-2);
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .card {
      position: relative;
      overflow: hidden;
      border-radius: var(--radius);
      padding: 12px 14px;
      min-height: 96px;
    }
    .card::after {
      content: "";
      position: absolute;
      inset: auto -24px -48px auto;
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255, 255, 255, 0.26), transparent 70%);
      filter: blur(10px);
    }
    .card:hover,
    .mini-stat:hover,
    .panel:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 36px rgba(30, 35, 41, 0.08);
      border-color: var(--line-strong);
    }
    .card.green {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 1), rgba(247, 249, 252, 0.98)),
        linear-gradient(135deg, rgba(15, 159, 114, 0.12), rgba(94, 90, 219, 0.04));
      border-color: rgba(15, 159, 114, 0.18);
      box-shadow: 0 10px 24px rgba(30, 35, 41, 0.05);
    }
    .card.red {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 1), rgba(247, 249, 252, 0.98)),
        linear-gradient(135deg, rgba(216, 63, 86, 0.10), rgba(112, 66, 20, 0.04));
      border-color: rgba(216, 63, 86, 0.18);
      box-shadow: 0 10px 24px rgba(30, 35, 41, 0.05);
    }
    .card.orange {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 1), rgba(247, 249, 252, 0.98)),
        linear-gradient(135deg, rgba(112, 66, 20, 0.10), rgba(94, 90, 219, 0.04));
      border-color: rgba(112, 66, 20, 0.18);
      box-shadow: 0 10px 24px rgba(30, 35, 41, 0.05);
    }
    .card .label {
      margin-bottom: 12px;
      color: var(--dim);
    }
    .card .value {
      position: relative;
      z-index: 1;
      font-size: 22px;
      line-height: 1.1;
      font-weight: 700;
      letter-spacing: -0.03em;
      color: var(--heading);
    }
    .card.green .value { color: #0f9f72; }
    .card.red .value { color: #bf3349; }
    .card.orange .value { color: var(--accent); }
    .table-shell {
      border-radius: var(--radius);
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.96);
      overflow: auto;
    }
    .detail-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
    }
    .detail-table thead th {
      position: sticky;
      top: 0;
      z-index: 1;
      background: linear-gradient(180deg, rgba(247, 249, 252, 0.98), rgba(240, 244, 249, 0.98));
      color: var(--accent-2);
    }
    .detail-table th,
    .detail-table td {
      padding: 9px 9px;
      border-bottom: 1px solid var(--line);
      text-align: right;
      white-space: nowrap;
      color: var(--soft);
    }
    .detail-table tbody tr:nth-child(even) {
      background: rgba(82, 88, 98, 0.035);
    }
    .detail-table tbody tr:hover {
      background: rgba(94, 90, 219, 0.06);
    }
    .detail-table th:first-child,
    .detail-table td:first-child,
    .detail-table th:nth-child(2),
    .detail-table td:nth-child(2) {
      text-align: left;
      color: #1e293b;
    }
    .chart-block + .chart-block {
      margin-top: 26px;
      padding-top: 24px;
      border-top: 1px solid var(--line);
    }
    .chart-scroll {
      width: 100%;
      overflow-x: auto;
      overflow-y: hidden;
      margin-top: 12px;
      padding-bottom: 8px;
      -webkit-overflow-scrolling: touch;
    }
    .chart-scroll + .chart-scroll {
      margin-top: 18px;
    }
    .chart-scroll > div {
      min-width: 720px;
    }
    .plotly-graph-div {
      min-height: 440px;
    }
    .chart-scroll .js-plotly-plot,
    .chart-scroll .plot-container,
    .chart-scroll .svg-container {
      width: 100% !important;
      max-width: 100% !important;
      border-radius: var(--radius);
    }
    .chart-scroll .js-plotly-plot {
      border: 1px solid var(--line);
      box-shadow: 0 10px 26px rgba(30, 35, 41, 0.05);
      overflow: hidden;
    }
    .chart-scroll .js-plotly-plot:hover {
      box-shadow: 0 14px 34px rgba(30, 35, 41, 0.08);
    }
    @media (max-width: 1120px) {
    }
    @media (max-width: 840px) {
      .shell {
        padding: 16px 12px 36px;
      }
      .hero-grid {
        grid-template-columns: 1fr;
      }
      .hero h1 {
        font-size: 24px;
      }
      .card .value {
        font-size: 20px;
      }
      .chart-scroll > div {
        min-width: 680px;
      }
      .plotly-graph-div {
        min-height: 420px;
      }
    }
    @media (max-width: 430px) {
      .shell {
        padding: 14px 12px 32px;
      }
      .hero,
      .panel {
        padding: 14px;
      }
      .hero h1 {
        font-size: 20px;
        line-height: 1.18;
      }
      .hero p,
      .panel-head p,
      .table-caption {
        font-size: 12px;
        line-height: 1.6;
      }
      .section-title {
        font-size: 17px;
        line-height: 1.25;
      }
      .panel-head {
        gap: 10px;
        margin-bottom: 12px;
      }
      .cards {
        grid-template-columns: 1fr 1fr;
      }
      .card {
        min-height: 84px;
        padding: 10px 11px;
      }
      .card .value,
      .mini-value {
        font-size: 18px;
      }
      .market-label {
        padding: 5px 8px;
        font-size: 10px;
      }
      .detail-table {
        font-size: 11px;
      }
      .detail-table th,
      .detail-table td {
        padding: 8px 7px;
      }
      .chart-block + .chart-block {
        margin-top: 20px;
        padding-top: 20px;
      }
      .chart-scroll {
        overflow-x: visible;
        margin-top: 10px;
        padding-bottom: 0;
      }
      .chart-scroll > div {
        min-width: 0 !important;
      }
      .plotly-graph-div {
        min-height: 360px;
      }
    }
    @media (max-width: 390px) {
      .shell {
        padding: 12px 10px 28px;
      }
      .hero,
      .panel {
        padding: 12px;
      }
      .cards {
        grid-template-columns: 1fr;
      }
      .hero h1 {
        font-size: 18px;
      }
      .section-title {
        font-size: 16px;
      }
      .plotly-graph-div {
        min-height: 340px;
      }
    }
  </style>
</head>
<body>
  <div class="shell">
      <main class="main">
        <section class="hero">
          <div class="hero-grid">
            <div>
              <div class="eyebrow">Performance Overview</div>
              <h1>股票庫存績效報表</h1>
              <p>以明亮簡潔風整理投資組合摘要、股票明細與互動式歷史績效圖，保留市場配色規則、折線填色與 0% 穿越分段上色邏輯。</p>
            </div>
            <div class="hero-stats">
              <div class="mini-stat">
                <div class="mini-label">Report Scope</div>
                <div class="mini-value">TW / US</div>
                <div class="mini-note">支援台股與美股報酬邏輯</div>
              </div>
              <div class="mini-stat">
                <div class="mini-label">Visual Mode</div>
                <div class="mini-value">Clean & Airy</div>
                <div class="mini-note">白底、柔和紫金 accent、簡潔展示型報表</div>
              </div>
            </div>
          </div>
        </section>

        <div class="stack">
          <section class="panel">
            <div class="panel-head">
              <div>
                <div class="panel-kicker">Portfolio Snapshot</div>
                <h2 class="section-title">投資組合總覽</h2>
              </div>
              <p>以明亮簡潔卡片呈現市場摘要，滑鼠移入可快速查看數值</p>
            </div>
            {% for group in summary_cards %}
            <div class="currency-block">
              <div class="market-label">{{ group.market_label }}</div>
              <div class="cards">
                {% for item in group.card_items %}
                <article class="card {{ item.tone }}" title="{{ item.label }}：{{ item.value }}">
                  <div class="label">{{ item.label }}</div>
                  <div class="value">{{ item.value }}</div>
                </article>
                {% endfor %}
              </div>
            </div>
            {% endfor %}
          </section>

          <section class="panel">
            <div class="panel-head">
              <div>
                <div class="panel-kicker">Holdings Table</div>
                <h2 class="section-title">股票明細</h2>
              </div>
              <p class="table-caption">即時成本 / 市值 / 總損益 / 總報酬率</p>
            </div>
            {% if table_html %}
            <div class="table-shell">
              {{ table_html | safe }}
            </div>
            {% else %}
            <p class="muted">目前沒有可顯示的股票明細。</p>
            {% endif %}
          </section>

          <section class="panel">
            <div class="panel-head">
              <div>
                <div class="panel-kicker">History & Return</div>
                <h2 class="section-title">歷史績效圖</h2>
              </div>
              <p>保留折線塗色、區間報酬率與分段上色邏輯，並優化手機與展示版面</p>
            </div>
            {% for section in plot_sections %}
            <div class="chart-block">
              <div class="market-label">{{ section.market_label }}</div>
              <div class="chart-scroll value-chart">{{ section.value_chart | safe }}</div>
              <div class="chart-scroll return-chart">{{ section.return_chart | safe }}</div>
            </div>
            {% endfor %}
          </section>
        </div>
      </main>
  </div>
  <script>
    (function () {
      const valueButtonsDesktop = [
        { count: 1, label: "1D", step: "day", stepmode: "backward" },
        { count: 7, label: "1W", step: "day", stepmode: "backward" },
        { count: 1, label: "1M", step: "month", stepmode: "backward" },
        { count: 1, label: "YTD", step: "year", stepmode: "todate" },
        { count: 1, label: "1Y", step: "year", stepmode: "backward" },
        { count: 3, label: "3Y", step: "year", stepmode: "backward" },
        { count: 5, label: "5Y", step: "year", stepmode: "backward" },
        { step: "all", label: "全部" }
      ];
      const valueButtonsMobile = [
        { count: 1, label: "1D", step: "day", stepmode: "backward" },
        { count: 7, label: "1W", step: "day", stepmode: "backward" },
        { count: 1, label: "1M", step: "month", stepmode: "backward" },
        { step: "all", label: "全部" }
      ];
      const chartState = new WeakMap();

      function clone(obj) {
        return JSON.parse(JSON.stringify(obj));
      }

      function rememberChartState(gd) {
        if (chartState.has(gd)) {
          return chartState.get(gd);
        }
        const state = {
          legend: clone(gd.layout.legend || {}),
          updatemenus: clone(gd.layout.updatemenus || []),
          xaxis: clone(gd.layout.xaxis || {}),
          yaxis: clone(gd.layout.yaxis || {}),
          margin: clone(gd.layout.margin || {})
        };
        chartState.set(gd, state);
        return state;
      }

      function relayoutValueChart(gd, mobile, state) {
        const update = {
          "font.size": mobile ? 11 : 13,
          "margin.l": mobile ? 34 : (state.margin.l || 44),
          "margin.r": mobile ? 10 : (state.margin.r || 24),
          "margin.t": mobile ? 88 : (state.margin.t || 108),
          "margin.b": mobile ? 34 : (state.margin.b || 44),
          "xaxis.tickfont.size": mobile ? 10 : (((state.xaxis || {}).tickfont || {}).size || 12),
          "yaxis.tickfont.size": mobile ? 10 : (((state.yaxis || {}).tickfont || {}).size || 12),
          "xaxis.nticks": mobile ? 4 : null,
          "legend.orientation": mobile ? "h" : (state.legend.orientation || "v"),
          "legend.x": mobile ? 0 : (state.legend.x ?? 1),
          "legend.y": mobile ? -0.2 : (state.legend.y ?? 1),
          "legend.xanchor": mobile ? "left" : (state.legend.xanchor || "left"),
          "legend.yanchor": mobile ? "top" : (state.legend.yanchor || "auto"),
          "xaxis.rangeselector.buttons": mobile ? valueButtonsMobile : valueButtonsDesktop
        };
        window.Plotly.relayout(gd, update);
      }

      function relayoutReturnChart(gd, mobile, state) {
        const baseMenu = clone((state.updatemenus && state.updatemenus[0]) || {});
        if (!baseMenu.buttons) {
          return;
        }
        const updateMenu = mobile
          ? [
              Object.assign(baseMenu, {
                type: "dropdown",
                direction: "down",
                showactive: true,
                x: 0,
                y: 1.18,
                xanchor: "left",
                yanchor: "top",
                font: Object.assign({}, baseMenu.font || {}, { size: 10 }),
                pad: { r: 0, t: 0, b: 0, l: 0 }
              })
            ]
          : state.updatemenus;

        const update = {
          "font.size": mobile ? 11 : 13,
          "margin.l": mobile ? 34 : (state.margin.l || 44),
          "margin.r": mobile ? 10 : (state.margin.r || 24),
          "margin.t": mobile ? 96 : (state.margin.t || 108),
          "margin.b": mobile ? 34 : (state.margin.b || 44),
          "xaxis.tickfont.size": mobile ? 10 : (((state.xaxis || {}).tickfont || {}).size || 12),
          "yaxis.tickfont.size": mobile ? 10 : (((state.yaxis || {}).tickfont || {}).size || 12),
          "xaxis.nticks": mobile ? 4 : null,
          "legend.orientation": mobile ? "h" : (state.legend.orientation || "v"),
          "legend.x": mobile ? 0 : (state.legend.x ?? 1),
          "legend.y": mobile ? -0.2 : (state.legend.y ?? 1),
          "legend.xanchor": mobile ? "left" : (state.legend.xanchor || "left"),
          "legend.yanchor": mobile ? "top" : (state.legend.yanchor || "auto"),
          updatemenus: updateMenu
        };
        window.Plotly.relayout(gd, update);
      }

      function applyResponsiveCharts() {
        if (!window.Plotly) {
          return;
        }
        const mobile = window.matchMedia("(max-width: 430px)").matches;

        document.querySelectorAll(".value-chart .js-plotly-plot").forEach((gd) => {
          const state = rememberChartState(gd);
          relayoutValueChart(gd, mobile, state);
        });

        document.querySelectorAll(".return-chart .js-plotly-plot").forEach((gd) => {
          const state = rememberChartState(gd);
          relayoutReturnChart(gd, mobile, state);
        });
      }

      function bindResponsiveCharts() {
        applyResponsiveCharts();
        window.addEventListener("resize", applyResponsiveCharts, { passive: true });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", bindResponsiveCharts);
      } else {
        bindResponsiveCharts();
      }
    })();
  </script>
</body>
</html>
