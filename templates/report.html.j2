<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#F4EADC">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="Ethan's Portfolio">
  <link rel="manifest" href="./manifest.webmanifest">
  <link rel="icon" href="./icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="./icon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Noto+Sans+TC:wght@400;500;700&family=Noto+Serif+TC:wght@500;700&display=swap" rel="stylesheet">
  <title>Ethan's Portfolio</title>
  <style>
    :root {
      --bg: #f7f3ec;
      --bg-soft: #fffcf7;
      --bg-tint: #eef4ef;
      --surface: rgba(255, 255, 255, 0.74);
      --surface-strong: rgba(255, 252, 247, 0.9);
      --surface-deep: #132238;
      --surface-ink: #1b2d45;
      --line: rgba(19, 34, 56, 0.08);
      --line-strong: rgba(19, 34, 56, 0.14);
      --text: #223249;
      --heading: #102038;
      --muted: #667085;
      --soft: #344054;
      --dim: #8b95a7;
      --brand: #132238;
      --brand-2: #0f9f72;
      --amber: #bc7a25;
      --red: #d83f56;
      --green: #0f9f72;
      --shadow-lg: 0 28px 70px rgba(15, 23, 42, 0.08);
      --shadow-md: 0 18px 44px rgba(15, 23, 42, 0.06);
      --shadow-sm: 0 10px 26px rgba(15, 23, 42, 0.05);
      --radius-xl: 32px;
      --radius-lg: 26px;
      --radius-md: 22px;
      --radius-sm: 16px;
      --transition: 180ms ease;
      --font-sans: "Aptos", "Segoe UI Variable Display", "Microsoft JhengHei", sans-serif;
      --font-numeric: "Bahnschrift", "Aptos", "Segoe UI Variable Display", "Microsoft JhengHei", sans-serif;
    }
    * { box-sizing: border-box; }
    html { background: var(--bg); }
    html.pwa-standalone,
    body.pwa-standalone {
      height: 100%;
      overflow-x: hidden;
    }
    body {
      margin: 0;
      min-height: 100vh;
      color: var(--soft);
      font-family: var(--font-sans);
      font-size: 14px;
      background:
        radial-gradient(circle at top left, rgba(19, 34, 56, 0.08), transparent 28%),
        radial-gradient(circle at 82% 14%, rgba(15, 159, 114, 0.12), transparent 24%),
        linear-gradient(180deg, var(--bg-soft) 0%, var(--bg) 52%, #f3efe7 100%);
      padding:
        env(safe-area-inset-top, 0px)
        env(safe-area-inset-right, 0px)
        env(safe-area-inset-bottom, 0px)
        env(safe-area-inset-left, 0px);
    }
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background:
        linear-gradient(rgba(19, 34, 56, 0.028) 1px, transparent 1px),
        linear-gradient(90deg, rgba(19, 34, 56, 0.028) 1px, transparent 1px);
      background-size: 28px 28px;
      mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.72), transparent);
      opacity: 0.48;
    }
    a { color: inherit; }
    .shell {
      position: relative;
      z-index: 1;
      max-width: 1480px;
      margin: 0 auto;
      padding: 24px 20px 56px;
    }
    .app-bar {
      display: none;
    }
    .topbar,
    .hero,
    .panel,
    .card,
    .status-tile,
    .chart-module {
      border: 1px solid var(--line);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.82) 0%, var(--surface) 100%);
      box-shadow: var(--shadow-md);
      backdrop-filter: blur(18px);
      transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
    }
    .topbar:hover,
    .hero:hover,
    .panel:hover,
    .chart-module:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-lg);
      border-color: var(--line-strong);
    }
    .eyebrow,
    .panel-kicker,
    .mini-label,
    .label,
    .table-caption,
    .module-kicker,
    .brand-eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-size: 10px;
    }
    .eyebrow,
    .panel-kicker,
    .mini-label,
    .label,
    .table-caption,
    .module-kicker,
    .brand-eyebrow,
    .muted {
      color: var(--dim);
    }
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      padding: 14px 18px;
      border-radius: 999px;
      margin-bottom: 18px;
    }
    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: 0;
    }
    .brand-mark {
      width: 42px;
      height: 42px;
      border-radius: 14px;
      background:
        radial-gradient(circle at 25% 22%, rgba(255, 255, 255, 0.72), transparent 28%),
        linear-gradient(135deg, var(--surface-deep) 0%, var(--brand-2) 100%);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.28);
      flex: 0 0 auto;
    }
    .brand-name {
      font-size: 17px;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--heading);
    }
    .topbar-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: flex-end;
    }
    .meta-pill,
    .market-label,
    .hero-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 8px 12px;
      background: rgba(255, 255, 255, 0.72);
      color: var(--soft);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      box-shadow: 0 8px 22px rgba(15, 23, 42, 0.04);
    }
    .meta-pill strong,
    .hero-tag strong {
      color: var(--heading);
      font-family: var(--font-numeric);
      letter-spacing: 0;
    }
    .meta-action {
      text-decoration: none;
      cursor: pointer;
      transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
    }
    .meta-action:hover {
      transform: translateY(-1px);
      box-shadow: 0 12px 26px rgba(15, 23, 42, 0.08);
    }
    .main {
      min-width: 0;
    }
    .hero {
      position: relative;
      overflow: hidden;
      border-radius: var(--radius-xl);
      padding: 28px;
      margin-bottom: 20px;
    }
    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 82% 22%, rgba(15, 159, 114, 0.18), transparent 24%),
        radial-gradient(circle at 14% 16%, rgba(19, 34, 56, 0.1), transparent 30%);
      pointer-events: none;
    }
    .hero::after {
      content: "";
      position: absolute;
      inset: auto -40px -94px auto;
      width: 260px;
      height: 260px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(188, 122, 37, 0.14), transparent 68%);
      filter: blur(18px);
      pointer-events: none;
    }
    .hero-grid {
      position: relative;
      z-index: 1;
      display: block;
    }
    .hero-copy {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 18px;
    }
    .hero h1 {
      margin: 10px 0 10px;
      font-size: 40px;
      line-height: 0.98;
      letter-spacing: -0.04em;
      color: var(--heading);
      max-width: 760px;
    }
    .hero p {
      margin: 0;
      max-width: 760px;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.75;
    }
    .hero-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .hero-tag {
      background: rgba(255, 252, 247, 0.84);
    }
    .stack {
      display: grid;
      gap: 18px;
    }
    .panel {
      border-radius: var(--radius-lg);
      padding: 22px;
      overflow: hidden;
    }
    .panel-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 18px;
      margin-bottom: 18px;
    }
    .panel-head p {
      margin: 6px 0 0;
      max-width: 380px;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.7;
      text-align: right;
    }
    .section-title {
      margin: 0 0 4px;
      font-size: 24px;
      line-height: 1.08;
      letter-spacing: -0.03em;
      color: var(--heading);
    }
    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
      gap: 14px;
    }
    .currency-block + .currency-block {
      margin-top: 22px;
    }
    .market-label {
      margin-bottom: 14px;
      border-color: rgba(15, 159, 114, 0.14);
      background: rgba(15, 159, 114, 0.08);
      color: var(--brand);
    }
    .card {
      position: relative;
      overflow: hidden;
      min-height: 128px;
      border-radius: var(--radius-md);
      padding: 18px;
    }
    .card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 18px;
      right: 18px;
      height: 3px;
      border-radius: 999px;
      background: rgba(19, 34, 56, 0.14);
    }
    .card::after {
      content: "";
      position: absolute;
      inset: auto -38px -68px auto;
      width: 160px;
      height: 160px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255, 255, 255, 0.22), transparent 70%);
      filter: blur(12px);
    }
    .card .label {
      position: relative;
      z-index: 1;
      margin-bottom: 14px;
    }
    .card .value {
      position: relative;
      z-index: 1;
      color: var(--heading);
      font-family: var(--font-numeric);
      font-size: 28px;
      line-height: 1.04;
      font-weight: 800;
      letter-spacing: -0.04em;
    }
    .card.slate {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(249, 246, 239, 0.94)),
        linear-gradient(135deg, rgba(19, 34, 56, 0.08), rgba(19, 34, 56, 0));
    }
    .card.slate::before { background: rgba(19, 34, 56, 0.18); }
    .card.slate .value { color: var(--surface-ink); }
    .card.brand {
      background:
        linear-gradient(180deg, rgba(19, 34, 56, 0.98), rgba(27, 45, 69, 0.96)),
        linear-gradient(135deg, rgba(15, 159, 114, 0.14), rgba(255, 255, 255, 0));
      border-color: rgba(19, 34, 56, 0.18);
      box-shadow: 0 20px 48px rgba(19, 34, 56, 0.16);
    }
    .card.brand::before { background: rgba(255, 255, 255, 0.36); }
    .card.brand .label,
    .card.brand .value { color: #f8fafc; }
    .card.gold {
      background:
        linear-gradient(180deg, rgba(255, 250, 240, 0.98), rgba(244, 228, 187, 0.98)),
        linear-gradient(135deg, rgba(188, 122, 37, 0.22), rgba(255, 255, 255, 0));
      border-color: rgba(188, 122, 37, 0.2);
      box-shadow: 0 18px 42px rgba(188, 122, 37, 0.16);
    }
    .card.gold::before { background: rgba(188, 122, 37, 0.5); }
    .card.gold .label { color: rgba(93, 57, 11, 0.72); }
    .card.gold .value { color: #8d5b14; }
    .card.teal {
      background:
        linear-gradient(180deg, rgba(240, 250, 248, 0.98), rgba(215, 239, 235, 0.98)),
        linear-gradient(135deg, rgba(19, 140, 125, 0.2), rgba(255, 255, 255, 0));
      border-color: rgba(19, 140, 125, 0.18);
      box-shadow: 0 18px 42px rgba(19, 140, 125, 0.14);
    }
    .card.teal::before { background: rgba(19, 140, 125, 0.46); }
    .card.teal .label { color: rgba(17, 86, 78, 0.72); }
    .card.teal .value { color: #11756b; }
    .card.amber {
      background:
        linear-gradient(180deg, rgba(255, 249, 239, 0.96), rgba(245, 234, 211, 0.96)),
        linear-gradient(135deg, rgba(188, 122, 37, 0.18), rgba(255, 255, 255, 0));
      border-color: rgba(188, 122, 37, 0.16);
    }
    .card.amber::before { background: rgba(188, 122, 37, 0.42); }
    .card.amber .value { color: #9b631d; }
    .card.green {
      background:
        linear-gradient(180deg, rgba(242, 250, 247, 0.96), rgba(227, 245, 236, 0.96)),
        linear-gradient(135deg, rgba(15, 159, 114, 0.18), rgba(255, 255, 255, 0));
      border-color: rgba(15, 159, 114, 0.18);
    }
    .card.green::before { background: rgba(15, 159, 114, 0.44); }
    .card.green .value { color: #0f9f72; }
    .card.red {
      background:
        linear-gradient(180deg, rgba(252, 243, 245, 0.96), rgba(250, 230, 235, 0.96)),
        linear-gradient(135deg, rgba(216, 63, 86, 0.16), rgba(255, 255, 255, 0));
      border-color: rgba(216, 63, 86, 0.18);
    }
    .card.red::before { background: rgba(216, 63, 86, 0.42); }
    .card.red .value { color: #c1324a; }
    .table-shell {
      border-radius: var(--radius-md);
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.92);
      overflow: auto;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.32);
    }
    .detail-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
    }
    .detail-table thead th {
      position: sticky;
      top: 0;
      z-index: 1;
      background: linear-gradient(180deg, rgba(249, 246, 239, 0.98), rgba(243, 238, 228, 0.98));
      color: var(--heading);
    }
    .detail-table th,
    .detail-table td {
      padding: 12px 12px;
      border-bottom: 1px solid var(--line);
      text-align: right;
      white-space: nowrap;
      color: var(--soft);
    }
    .detail-table tbody tr:nth-child(even) {
      background: rgba(19, 34, 56, 0.024);
    }
    .detail-table tbody tr:hover {
      background: rgba(15, 159, 114, 0.06);
    }
    .detail-table th:first-child,
    .detail-table td:first-child,
    .detail-table th:nth-child(2),
    .detail-table td:nth-child(2) {
      text-align: left;
      color: var(--heading);
    }
    .detail-table td:first-child {
      font-family: var(--font-numeric);
      font-weight: 700;
      letter-spacing: 0.02em;
    }
    .chart-block + .chart-block {
      margin-top: 28px;
      padding-top: 28px;
      border-top: 1px solid var(--line);
    }
    .chart-controls {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin: 12px 0 14px;
      flex-wrap: wrap;
    }
    .chart-switcher {
      display: none;
    }
    .chart-period-select {
      display: inline-flex;
      position: relative;
      width: fit-content;
    }
    .chart-period-select select {
      appearance: none;
      -webkit-appearance: none;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.92);
      color: var(--heading);
      padding: 10px 40px 10px 14px;
      font: inherit;
      font-size: 12px;
      font-weight: 700;
      box-shadow: var(--shadow-sm);
    }
    .chart-period-select::after {
      content: "▼";
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      pointer-events: none;
      color: var(--muted);
      font-size: 11px;
    }
    .chart-grid {
      display: grid;
      gap: 16px;
    }
    .chart-module {
      border-radius: var(--radius-md);
      padding: 16px;
    }
    .module-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 10px;
    }
    .module-title {
      margin: 4px 0 0;
      color: var(--heading);
      font-size: 18px;
      letter-spacing: -0.02em;
    }
    .module-note {
      max-width: 300px;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.65;
      text-align: right;
    }
    .chart-scroll {
      width: 100%;
      overflow-x: auto;
      overflow-y: hidden;
      margin-top: 8px;
      padding-bottom: 8px;
      -webkit-overflow-scrolling: touch;
    }
    .allocation-scroll > div {
      min-width: 420px !important;
    }
    .allocation-scroll .plotly-graph-div {
      min-height: 420px;
    }
    .chart-scroll > div {
      min-width: 720px;
    }
    .plotly-graph-div {
      min-height: 440px;
    }
    .chart-scroll .js-plotly-plot,
    .chart-scroll .plot-container,
    .chart-scroll .svg-container {
      width: 100% !important;
      max-width: 100% !important;
      border-radius: calc(var(--radius-md) - 6px);
    }
    .chart-scroll .js-plotly-plot {
      border: 1px solid var(--line);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
      background: rgba(255, 252, 247, 0.88);
    }
    .chart-scroll .js-plotly-plot:hover {
      box-shadow: var(--shadow-md);
    }
    .pwa-standalone .shell {
      padding-top: max(16px, env(safe-area-inset-top, 0px));
      padding-bottom: max(24px, env(safe-area-inset-bottom, 0px));
    }
    .pwa-standalone .hero {
      padding-top: 20px;
    }
    @media (max-width: 1040px) {
      .topbar {
        border-radius: 28px;
      }
    }
    @media (max-width: 840px) {
      .shell {
        padding: 16px 12px 40px;
      }
      .topbar {
        flex-direction: column;
        align-items: stretch;
      }
      .topbar-meta {
        justify-content: flex-start;
      }
      .hero h1 {
        font-size: 32px;
      }
      .section-title {
        font-size: 21px;
      }
      .chart-scroll > div {
        min-width: 680px;
      }
      .allocation-scroll > div {
        min-width: 0 !important;
      }
      .plotly-graph-div {
        min-height: 420px;
      }
    }
    @media (max-width: 430px) {
      .shell {
        padding: 14px 12px 32px;
      }
      .topbar,
      .hero,
      .panel,
      .chart-module {
        padding: 14px;
      }
      .hero h1 {
        font-size: 26px;
        line-height: 1.02;
      }
      .hero p,
      .panel-head p,
      .table-caption,
      .module-note {
        font-size: 12px;
        line-height: 1.7;
      }
      .panel-head,
      .module-head {
        align-items: flex-start;
        flex-direction: column;
      }
      .section-title {
        font-size: 19px;
      }
      .cards {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
      }
      .card {
        min-height: 88px;
        padding: 12px;
      }
      .card::before {
        left: 12px;
        right: 12px;
      }
      .card .label {
        margin-bottom: 8px;
        font-size: 9px;
        letter-spacing: 0;
      }
      .card .value,
      .status-value {
        font-size: 22px;
      }
      .detail-table {
        font-size: 11px;
      }
      .detail-table th,
      .detail-table td {
        padding: 9px 8px;
      }
      .chart-controls {
        align-items: stretch;
      }
      .chart-period-select {
        width: 100%;
      }
      .chart-period-select select {
        width: 100%;
      }
      .chart-scroll {
        overflow-x: visible;
        padding-bottom: 0;
      }
      .chart-scroll > div {
        min-width: 0 !important;
      }
      .allocation-scroll .plotly-graph-div {
        min-height: 320px;
      }
      .plotly-graph-div {
        min-height: 360px;
      }
    }
    @media (display-mode: standalone) and (max-width: 430px) {
      .app-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        position: sticky;
        top: 0;
        z-index: 20;
        margin: 0 0 10px;
        padding: 10px 12px 12px;
        border: 1px solid var(--line);
        border-radius: 20px;
        background: rgba(255, 252, 247, 0.88);
        backdrop-filter: blur(18px);
        box-shadow: var(--shadow-sm);
      }
      .app-bar-title {
        font-size: 15px;
        font-weight: 800;
        color: var(--heading);
        letter-spacing: -0.02em;
      }
      .app-bar-note {
        margin-top: 3px;
        font-size: 11px;
        color: var(--dim);
      }
      .chart-switcher {
        display: inline-flex;
        gap: 4px;
        padding: 4px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.9);
        border-radius: 999px;
      }
      .chart-switcher button {
        border: 0;
        background: transparent;
        color: var(--muted);
        padding: 7px 12px;
        border-radius: 999px;
        font: inherit;
        font-size: 12px;
        font-weight: 700;
      }
      .chart-switcher button.is-active {
        background: var(--surface-deep);
        color: #f8fafc;
        box-shadow: 0 8px 18px rgba(19, 34, 56, 0.18);
      }
      .chart-scroll.is-hidden {
        display: none;
      }
      .plotly-graph-div {
        min-height: min(48vh, 420px);
      }
    }
    /* Flux Bento overrides */
    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap');
    :root {
      --bg: #0d1824;
      --bg-soft: #09111a;
      --bg-tint: #112131;
      --surface: rgba(255, 255, 255, 0.07);
      --surface-strong: rgba(255, 255, 255, 0.11);
      --surface-deep: #0f1d2b;
      --surface-ink: #f2fbff;
      --line: rgba(255, 255, 255, 0.10);
