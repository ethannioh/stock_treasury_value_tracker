<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#5E5ADB">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="股票報表">
  <link rel="manifest" href="./manifest.webmanifest">
  <link rel="icon" href="./icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="./icon.svg">
  <title>股票庫存績效報表</title>
  <style>
    :root {
      --bg: #ffffff;
      --bg-2: #f7f9fc;
      --panel: rgba(247, 249, 252, 0.94);
      --panel-strong: rgba(255, 255, 255, 0.98);
      --line: rgba(30, 35, 41, 0.10);
      --line-strong: rgba(30, 35, 41, 0.16);
      --text: #1e2329;
      --heading: #1e2329;
      --muted: #66717f;
      --soft: #1e2329;
      --dim: #8d98a7;
      --accent: #704214;
      --accent-2: #5e5adb;
      --glow: rgba(94, 90, 219, 0.10);
      --shadow: 0 10px 30px rgba(30, 35, 41, 0.06);
      --red: #d83f56;
      --green: #0f9f72;
      --orange: #704214;
      --radius: 8px;
      --transition: 180ms ease;
    }
    * { box-sizing: border-box; }
    html { background: var(--bg); }
    html.pwa-standalone,
    body.pwa-standalone {
      height: 100%;
      overflow-x: hidden;
    }
    body {
      margin: 0;
      color: var(--soft);
      font-family: Inter, Roboto, "SF Pro Text", "Helvetica Neue", Arial, "Microsoft JhengHei", sans-serif;
      font-size: 14px;
      background: linear-gradient(180deg, var(--bg) 0%, var(--bg-2) 100%);
      min-height: 100vh;
      padding:
        env(safe-area-inset-top, 0px)
        env(safe-area-inset-right, 0px)
        env(safe-area-inset-bottom, 0px)
        env(safe-area-inset-left, 0px);
    }
    .shell {
      max-width: 1440px;
      margin: 0 auto;
      padding: 28px 20px 56px;
    }
    .app-bar {
      display: none;
    }
    .hero,
    .panel,
    .card,
    .mini-stat {
      border: 1px solid var(--line);
      background: linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, var(--panel) 100%);
      box-shadow: var(--shadow);
      transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition), background-color var(--transition);
    }
    .eyebrow,
    .panel-kicker,
    .mini-label,
    .label,
    .table-caption {
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-size: 10px;
    }
    .eyebrow,
    .panel-kicker,
    .mini-label,
    .label,
    .table-caption,
    .muted {
      color: var(--dim);
    }
    .main {
      min-width: 0;
    }
    .hero {
      position: relative;
      overflow: hidden;
      border-radius: var(--radius);
      padding: 20px 22px;
      margin-bottom: 20px;
    }
    .hero::after {
      content: "";
      position: absolute;
      inset: auto -20px -70px auto;
      width: 220px;
      height: 220px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(94, 90, 219, 0.10), transparent 68%);
      filter: blur(14px);
    }
    .hero-grid {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: minmax(0, 1.6fr) minmax(280px, 0.8fr);
      gap: 18px;
      align-items: end;
    }
    .hero h1 {
      margin: 10px 0 10px;
      font-size: 24px;
      line-height: 1.12;
      letter-spacing: 0.02em;
      color: var(--accent);
    }
    .hero p {
      margin: 0;
      max-width: 720px;
      color: var(--dim);
      font-size: 13px;
      line-height: 1.6;
    }
    .hero-stats {
      display: grid;
      gap: 12px;
    }
    .mini-stat {
      border-radius: var(--radius);
      padding: 12px 14px;
      background: rgba(247, 249, 252, 0.92);
    }
    .mini-value {
      margin-top: 8px;
      font-size: 22px;
      font-weight: 700;
      color: var(--accent-2);
    }
    .mini-note {
      margin-top: 6px;
      color: var(--dim);
      font-size: 11px;
    }
    .section-title {
      margin: 0 0 14px;
      font-size: 18px;
      letter-spacing: 0.03em;
      color: var(--heading);
    }
    .stack {
      display: grid;
      gap: 18px;
    }
    .panel {
      border-radius: var(--radius);
      padding: 18px;
      overflow: hidden;
    }
    .panel-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 16px;
    }
    .panel-head p {
      margin: 6px 0 0;
      color: var(--dim);
      font-size: 12px;
    }
    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 10px;
    }
    .currency-block + .currency-block {
      margin-top: 18px;
    }
    .market-label {
      display: inline-flex;
      margin-bottom: 12px;
      padding: 6px 10px;
      border: 1px solid var(--line-strong);
      background: rgba(94, 90, 219, 0.06);
      color: var(--accent-2);
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .card {
      position: relative;
      overflow: hidden;
      border-radius: var(--radius);
      padding: 12px 14px;
      min-height: 96px;
    }
    .card::after {
      content: "";
      position: absolute;
      inset: auto -24px -48px auto;
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255, 255, 255, 0.26), transparent 70%);
      filter: blur(10px);
    }
    .card:hover,
    .mini-stat:hover,
    .panel:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 36px rgba(30, 35, 41, 0.08);
      border-color: var(--line-strong);
    }
    .card.green {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 1), rgba(247, 249, 252, 0.98)),
        linear-gradient(135deg, rgba(15, 159, 114, 0.12), rgba(94, 90, 219, 0.04));
      border-color: rgba(15, 159, 114, 0.18);
      box-shadow: 0 10px 24px rgba(30, 35, 41, 0.05);
    }
    .card.red {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 1), rgba(247, 249, 252, 0.98)),
        linear-gradient(135deg, rgba(216, 63, 86, 0.10), rgba(112, 66, 20, 0.04));
      border-color: rgba(216, 63, 86, 0.18);
      box-shadow: 0 10px 24px rgba(30, 35, 41, 0.05);
    }
    .card.orange {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 1), rgba(247, 249, 252, 0.98)),
        linear-gradient(135deg, rgba(112, 66, 20, 0.10), rgba(94, 90, 219, 0.04));
      border-color: rgba(112, 66, 20, 0.18);
      box-shadow: 0 10px 24px rgba(30, 35, 41, 0.05);
    }
    .card .label {
      margin-bottom: 12px;
      color: var(--dim);
    }
    .card .value {
      position: relative;
      z-index: 1;
      font-size: 22px;
      line-height: 1.1;
      font-weight: 700;
      letter-spacing: -0.03em;
      color: var(--heading);
    }
    .card.green .value { color: #0f9f72; }
    .card.red .value { color: #bf3349; }
    .card.orange .value { color: var(--accent); }
    .table-shell {
      border-radius: var(--radius);
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.96);
      overflow: auto;
    }
    .detail-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
    }
    .detail-table thead th {
      position: sticky;
      top: 0;
      z-index: 1;
      background: linear-gradient(180deg, rgba(247, 249, 252, 0.98), rgba(240, 244, 249, 0.98));
      color: var(--accent-2);
    }
    .detail-table th,
    .detail-table td {
      padding: 9px 9px;
      border-bottom: 1px solid var(--line);
      text-align: right;
      white-space: nowrap;
      color: var(--soft);
    }
    .detail-table tbody tr:nth-child(even) {
      background: rgba(82, 88, 98, 0.035);
    }
    .detail-table tbody tr:hover {
      background: rgba(94, 90, 219, 0.06);
    }
    .detail-table th:first-child,
    .detail-table td:first-child,
    .detail-table th:nth-child(2),
    .detail-table td:nth-child(2) {
      text-align: left;
      color: #1e293b;
    }
    .chart-block + .chart-block {
      margin-top: 26px;
      padding-top: 24px;
      border-top: 1px solid var(--line);
    }
    .chart-switcher {
      display: none;
    }
    .chart-period-select {
      display: none;
    }
    .chart-scroll {
      width: 100%;
      overflow-x: auto;
      overflow-y: hidden;
      margin-top: 12px;
      padding-bottom: 8px;
      -webkit-overflow-scrolling: touch;
    }
    .chart-scroll + .chart-scroll {
      margin-top: 18px;
    }
    .allocation-scroll > div {
      min-width: 420px !important;
    }
    .allocation-scroll .plotly-graph-div {
      min-height: 420px;
    }
    .chart-scroll > div {
      min-width: 720px;
    }
    .plotly-graph-div {
      min-height: 440px;
    }
    .chart-scroll .js-plotly-plot,
    .chart-scroll .plot-container,
    .chart-scroll .svg-container {
      width: 100% !important;
      max-width: 100% !important;
      border-radius: var(--radius);
    }
    .chart-scroll .js-plotly-plot {
      border: 1px solid var(--line);
      box-shadow: 0 10px 26px rgba(30, 35, 41, 0.05);
      overflow: hidden;
    }
    .chart-scroll .js-plotly-plot:hover {
      box-shadow: 0 14px 34px rgba(30, 35, 41, 0.08);
    }
    .pwa-standalone .shell {
      padding-top: max(16px, env(safe-area-inset-top, 0px));
      padding-bottom: max(24px, env(safe-area-inset-bottom, 0px));
    }
    .pwa-standalone .hero {
      padding-top: 16px;
    }
    .pwa-standalone .chart-scroll {
      margin-top: 8px;
    }
    .pwa-standalone .plotly-graph-div {
      min-height: 520px;
    }
    @media (max-width: 1120px) {
    }
    @media (max-width: 840px) {
      .shell {
        padding: 16px 12px 36px;
      }
      .hero-grid {
        grid-template-columns: 1fr;
      }
      .hero h1 {
        font-size: 24px;
      }
      .card .value {
        font-size: 20px;
      }
      .chart-scroll > div {
        min-width: 680px;
      }
      .allocation-scroll > div {
        min-width: 0 !important;
      }
      .plotly-graph-div {
        min-height: 420px;
      }
    }
    @media (max-width: 430px) {
      .shell {
        padding: 14px 12px 32px;
      }
      .hero,
      .panel {
        padding: 14px;
      }
      .hero h1 {
        font-size: 20px;
        line-height: 1.18;
      }
      .hero p,
      .panel-head p,
      .table-caption {
        font-size: 12px;
        line-height: 1.6;
      }
      .section-title {
        font-size: 17px;
        line-height: 1.25;
      }
      .panel-head {
        gap: 10px;
        margin-bottom: 12px;
      }
      .cards {
        grid-template-columns: 1fr 1fr;
      }
      .card {
        min-height: 84px;
        padding: 10px 11px;
      }
      .card .value,
      .mini-value {
        font-size: 18px;
      }
      .market-label {
        padding: 5px 8px;
        font-size: 10px;
      }
      .detail-table {
        font-size: 11px;
      }
      .detail-table th,
      .detail-table td {
        padding: 8px 7px;
      }
      .chart-block + .chart-block {
        margin-top: 20px;
        padding-top: 20px;
      }
      .chart-scroll {
        overflow-x: visible;
        margin-top: 10px;
        padding-bottom: 0;
      }
      .chart-scroll > div {
        min-width: 0 !important;
      }
      .allocation-scroll .plotly-graph-div {
        min-height: 320px;
      }
      .plotly-graph-div {
        min-height: 360px;
      }
    }
    @media (max-width: 390px) {
      .shell {
        padding: 12px 10px 28px;
      }
      .hero,
      .panel {
        padding: 12px;
      }
      .cards {
        grid-template-columns: 1fr;
      }
      .hero h1 {
        font-size: 18px;
      }
      .section-title {
        font-size: 16px;
      }
      .plotly-graph-div {
        min-height: 340px;
      }
    }
    @media (display-mode: standalone) and (max-width: 430px) {
      .app-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        position: sticky;
        top: 0;
        z-index: 20;
        margin: 0 0 10px;
        padding: 8px 10px 12px;
        background: rgba(255, 255, 255, 0.88);
        backdrop-filter: blur(14px);
      }
      .app-bar-title {
        font-size: 16px;
        font-weight: 700;
        color: var(--heading);
        letter-spacing: -0.01em;
      }
      .app-bar-note {
        margin-top: 3px;
        text-align: center;
        font-size: 11px;
        color: var(--dim);
      }
      .hero {
        padding-top: 10px;
      }
      .hero-grid {
        gap: 12px;
      }
      .hero-stats {
        grid-template-columns: 1fr 1fr;
      }
      .panel-head {
        align-items: flex-start;
        flex-direction: column;
      }
      .chart-switcher {
        display: inline-flex;
        gap: 4px;
        padding: 4px;
        border: 1px solid var(--line);
        background: #f2f4f8;
        border-radius: 999px;
        margin: 8px 0 2px;
      }
      .chart-switcher button {
        border: 0;
        background: transparent;
        color: var(--muted);
        padding: 7px 12px;
        border-radius: 999px;
        font: inherit;
        font-size: 12px;
        font-weight: 700;
      }
      .chart-switcher button.is-active {
        background: #ffffff;
        color: var(--accent-2);
        box-shadow: 0 4px 10px rgba(30, 35, 41, 0.08);
      }
      .chart-period-select {
        display: block;
        margin: 10px 0 8px;
      }
      .chart-period-select select {
        appearance: none;
        -webkit-appearance: none;
        width: 120px;
        border: 1px solid var(--line);
        border-radius: 10px;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(247, 249, 252, 0.98));
        color: var(--muted);
        padding: 12px 38px 12px 14px;
        font: inherit;
        font-size: 12px;
        font-weight: 700;
        box-shadow: 0 6px 18px rgba(30, 35, 41, 0.06);
      }
      .chart-period-select {
        position: relative;
        width: fit-content;
      }
      .chart-period-select::after {
        content: "▼";
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
        color: var(--muted);
        font-size: 11px;
      }
      .chart-scroll.is-hidden {
        display: none;
      }
      .plotly-graph-div {
        min-height: min(48vh, 420px);
      }
      .hero,
      .panel {
        padding-left: 12px;
        padding-right: 12px;
      }
    }
  </style>
</head>
<body>
  <div class="shell">
      <div class="app-bar">
        <div>
          <div class="app-bar-title">股票庫存績效報表</div>
          <div class="app-bar-note">{{ generated_at }}</div>
        </div>
      </div>
      <main class="main">
        <section class="hero">
          <div class="hero-grid">
            <div>
              <div class="eyebrow">Performance Overview</div>
              <h1>股票庫存績效報表</h1>
              <p>以明亮簡潔風整理投資組合摘要、股票明細與互動式歷史績效圖，保留市場配色規則、折線填色與 0% 穿越分段上色邏輯。</p>
            </div>
            <div class="hero-stats">
              <div class="mini-stat">
                <div class="mini-label">Report Scope</div>
                <div class="mini-value">TW / US</div>
                <div class="mini-note">支援台股與美股報酬邏輯</div>
              </div>
              <div class="mini-stat">
                <div class="mini-label">Visual Mode</div>
                <div class="mini-value">Clean & Airy</div>
                <div class="mini-note">白底、柔和紫金 accent、簡潔展示型報表</div>
              </div>
            </div>
          </div>
        </section>

        <div class="stack">
          <section class="panel">
            <div class="panel-head">
              <div>
                <div class="panel-kicker">Portfolio Snapshot</div>
                <h2 class="section-title">投資組合總覽</h2>
              </div>
              <p>以明亮簡潔卡片呈現市場摘要，滑鼠移入可快速查看數值</p>
            </div>
            {% for group in summary_cards %}
            <div class="currency-block">
              <div class="market-label">{{ group.market_label }}</div>
              <div class="cards">
                {% for item in group.card_items %}
                <article class="card {{ item.tone }}" title="{{ item.label }}：{{ item.value }}">
                  <div class="label">{{ item.label }}</div>
                  <div class="value">{{ item.value }}</div>
                </article>
                {% endfor %}
              </div>
            </div>
            {% endfor %}
          </section>

          <section class="panel">
            <div class="panel-head">
              <div>
                <div class="panel-kicker">Holdings Table</div>
                <h2 class="section-title">股票明細</h2>
              </div>
              <p class="table-caption">即時成本 / 市值 / 總損益 / 總報酬率</p>
            </div>
            {% if table_html %}
            <div class="table-shell">
              {{ table_html | safe }}
            </div>
            {% else %}
            <p class="muted">目前沒有可顯示的股票明細。</p>
            {% endif %}
          </section>

          <section class="panel">
            <div class="panel-head">
              <div>
                <div class="panel-kicker">History & Return</div>
                <h2 class="section-title">歷史績效圖</h2>
              </div>
              <p>保留折線塗色、區間報酬率與分段上色邏輯，並優化手機與展示版面</p>
            </div>
            {% for section in plot_sections %}
            <div class="chart-block">
              <div class="market-label">{{ section.market_label }}</div>
              <div class="panel-head" style="margin-bottom: 10px;">
                <div>
                  <div class="panel-kicker">Performance</div>
                  <h3 class="section-title">績效圖</h3>
                </div>
              </div>
              <div class="chart-switcher" data-chart-group="{{ loop.index0 }}">
                <button type="button" class="is-active" data-target="value">市值</button>
                <button type="button" data-target="return">報酬率</button>
              </div>
              <label class="chart-period-select" data-chart-group="{{ loop.index0 }}">
                <select data-chart-group="{{ loop.index0 }}" aria-label="選擇時間區間">
                  <option value="1D">1D</option>
                  <option value="1W">1W</option>
                  <option value="1M" selected>1M</option>
                  <option value="YTD">YTD</option>
                  <option value="1Y">1Y</option>
                  <option value="3Y">3Y</option>
                  <option value="5Y">5Y</option>
                  <option value="全部">全部</option>
                </select>
              </label>
              <div class="chart-scroll value-chart" data-chart-group="{{ loop.index0 }}" data-chart-kind="value">{{ section.value_chart | safe }}</div>
              <div class="chart-scroll return-chart" data-chart-group="{{ loop.index0 }}" data-chart-kind="return">{{ section.return_chart | safe }}</div>
              <div class="panel-head" style="margin: 18px 0 10px;">
                <div>
                  <div class="panel-kicker">Allocation</div>
                  <h3 class="section-title">持股市值占比</h3>
                </div>
                <p>以目前各持股淨值計算占比</p>
              </div>
              <div class="chart-scroll allocation-scroll" data-chart-group="{{ loop.index0 }}" data-chart-kind="allocation">{{ section.allocation_chart | safe }}</div>
            </div>
            {% endfor %}
          </section>
        </div>
      </main>
  </div>
  <script>
    (function () {
      const isStandalone = window.matchMedia("(display-mode: standalone)").matches || window.navigator.standalone === true;
      if (isStandalone) {
        document.documentElement.classList.add("pwa-standalone");
        document.body.classList.add("pwa-standalone");
      }

      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("./service-worker.js").catch(() => {});
        });
      }

      const valueButtonsDesktop = [
        { count: 1, label: "1D", step: "day", stepmode: "backward" },
        { count: 7, label: "1W", step: "day", stepmode: "backward" },
        { count: 1, label: "1M", step: "month", stepmode: "backward" },
        { count: 1, label: "YTD", step: "year", stepmode: "todate" },
        { count: 1, label: "1Y", step: "year", stepmode: "backward" },
        { count: 3, label: "3Y", step: "year", stepmode: "backward" },
        { count: 5, label: "5Y", step: "year", stepmode: "backward" },
        { step: "all", label: "全部" }
      ];
      const valueButtonsMobile = [
        { count: 1, label: "1D", step: "day", stepmode: "backward" },
        { count: 7, label: "1W", step: "day", stepmode: "backward" },
        { count: 1, label: "1M", step: "month", stepmode: "backward" },
        { step: "all", label: "全部" }
      ];
      const chartState = new WeakMap();

      function clone(obj) {
        return JSON.parse(JSON.stringify(obj));
      }

      function rememberChartState(gd) {
        if (chartState.has(gd)) {
          return chartState.get(gd);
        }
        const state = {
          legend: clone(gd.layout.legend || {}),
          updatemenus: clone(gd.layout.updatemenus || []),
          xaxis: clone(gd.layout.xaxis || {}),
          yaxis: clone(gd.layout.yaxis || {}),
          margin: clone(gd.layout.margin || {})
        };
        chartState.set(gd, state);
        return state;
      }

      function relayoutValueChart(gd, mobile, state) {
        const pwaPhone = isStandalone && window.matchMedia("(max-width: 430px)").matches;
        const update = {
          "font.size": mobile ? 11 : 13,
          "margin.l": mobile ? 34 : (state.margin.l || 44),
          "margin.r": mobile ? 10 : (state.margin.r || 24),
          "margin.t": mobile ? (pwaPhone ? 74 : 88) : (state.margin.t || 108),
          "margin.b": mobile ? 34 : (state.margin.b || 44),
          "xaxis.tickfont.size": mobile ? 10 : (((state.xaxis || {}).tickfont || {}).size || 12),
          "yaxis.tickfont.size": mobile ? 10 : (((state.yaxis || {}).tickfont || {}).size || 12),
          "xaxis.nticks": mobile ? 4 : null,
          "legend.orientation": mobile ? "h" : (state.legend.orientation || "v"),
          "legend.x": mobile ? 0 : (state.legend.x ?? 1),
          "legend.y": mobile ? -0.2 : (state.legend.y ?? 1),
          "legend.xanchor": mobile ? "left" : (state.legend.xanchor || "left"),
          "legend.yanchor": mobile ? "top" : (state.legend.yanchor || "auto"),
          "xaxis.rangeselector.visible": mobile ? false : true,
          "xaxis.rangeselector.buttons": mobile ? valueButtonsDesktop : valueButtonsDesktop,
          height: pwaPhone ? Math.min(window.innerHeight * 0.34, 300) : null
        };
        window.Plotly.relayout(gd, update);
      }

      function relayoutReturnChart(gd, mobile, state) {
        const pwaPhone = isStandalone && window.matchMedia("(max-width: 430px)").matches;
        const baseMenu = clone((state.updatemenus && state.updatemenus[0]) || {});
        if (!baseMenu.buttons) {
          return;
        }
        const updateMenu = mobile
          ? []
          : state.updatemenus;

        const update = {
          "font.size": mobile ? 11 : 13,
          "margin.l": mobile ? 34 : (state.margin.l || 44),
          "margin.r": mobile ? 10 : (state.margin.r || 24),
          "margin.t": mobile ? (pwaPhone ? 84 : 96) : (state.margin.t || 108),
          "margin.b": mobile ? 34 : (state.margin.b || 44),
          "xaxis.tickfont.size": mobile ? 10 : (((state.xaxis || {}).tickfont || {}).size || 12),
          "yaxis.tickfont.size": mobile ? 10 : (((state.yaxis || {}).tickfont || {}).size || 12),
          "xaxis.nticks": mobile ? 4 : null,
          "legend.orientation": mobile ? "h" : (state.legend.orientation || "v"),
          "legend.x": mobile ? 0 : (state.legend.x ?? 1),
          "legend.y": mobile ? -0.2 : (state.legend.y ?? 1),
          "legend.xanchor": mobile ? "left" : (state.legend.xanchor || "left"),
          "legend.yanchor": mobile ? "top" : (state.legend.yanchor || "auto"),
          updatemenus: updateMenu,
          height: pwaPhone ? Math.min(window.innerHeight * 0.42, 360) : null
        };
        window.Plotly.relayout(gd, update);
      }

      function applyResponsiveCharts() {
        if (!window.Plotly) {
          return;
        }
        const mobile = window.matchMedia("(max-width: 430px)").matches;

        document.querySelectorAll(".value-chart .js-plotly-plot").forEach((gd) => {
          const state = rememberChartState(gd);
          relayoutValueChart(gd, mobile, state);
        });

        document.querySelectorAll(".return-chart .js-plotly-plot").forEach((gd) => {
          const state = rememberChartState(gd);
          relayoutReturnChart(gd, mobile, state);
        });
      }

      function getDateRange(xValues, period) {
        if (!xValues || !xValues.length) {
          return null;
        }
        const dates = xValues
          .map((value) => new Date(value))
          .filter((value) => !Number.isNaN(value.getTime()));
        if (!dates.length) {
          return null;
        }

        const end = dates[dates.length - 1];
        if (period === "全部") {
          return null;
        }
        if (period === "1D") {
          const start = dates[Math.max(0, dates.length - 2)];
          return [start, end];
        }

        const start = new Date(end);
        if (period === "1W") {
          start.setDate(start.getDate() - 7);
        } else if (period === "1M") {
          start.setMonth(start.getMonth() - 1);
        } else if (period === "YTD") {
          start.setMonth(0, 1);
        } else if (period === "1Y") {
          start.setFullYear(start.getFullYear() - 1);
        } else if (period === "3Y") {
          start.setFullYear(start.getFullYear() - 3);
        } else if (period === "5Y") {
          start.setFullYear(start.getFullYear() - 5);
        } else {
          return null;
        }
        return [start, end];
      }

      function applyValuePeriod(gd, period) {
        const xValues = (gd.data && gd.data[0] && gd.data[0].x) || [];
        const range = getDateRange(xValues, period);
        if (!range) {
          window.Plotly.relayout(gd, { "xaxis.autorange": true });
          return;
        }
        window.Plotly.relayout(gd, {
          "xaxis.autorange": false,
          "xaxis.range": range
        });
      }

      function applyReturnPeriod(gd, period) {
        const state = rememberChartState(gd);
        const menu = state && state.updatemenus && state.updatemenus[0];
        const buttons = (menu && menu.buttons) || [];
        const button = buttons.find((item) => item.label === period);
        if (!button || !button.args) {
          return;
        }
        const dataUpdate = button.args[0] || {};
        const layoutUpdate = button.args[1] || {};
        window.Plotly.update(gd, dataUpdate, layoutUpdate);
      }

      function initPeriodSelects() {
        const mobile = window.matchMedia("(max-width: 430px)").matches;
        document.querySelectorAll(".chart-period-select select").forEach((select) => {
          const group = select.dataset.chartGroup;
          const valueChart = document.querySelector('.value-chart[data-chart-group="' + group + '"] .js-plotly-plot');
          const returnChart = document.querySelector('.return-chart[data-chart-group="' + group + '"] .js-plotly-plot');

          select.onchange = () => {
            const period = select.value;
            if (valueChart) {
              applyValuePeriod(valueChart, period);
            }
            if (returnChart) {
              applyReturnPeriod(returnChart, period);
            }
          };

          if (mobile) {
            select.dispatchEvent(new Event("change"));
          }
        });
      }

      function initChartSwitchers() {
        const phonePwa = isStandalone && window.matchMedia("(max-width: 430px)").matches;
        document.querySelectorAll(".chart-switcher").forEach((switcher) => {
          const group = switcher.dataset.chartGroup;
          const buttons = switcher.querySelectorAll("button");
          const charts = document.querySelectorAll('.chart-scroll[data-chart-group="' + group + '"][data-chart-kind="value"], .chart-scroll[data-chart-group="' + group + '"][data-chart-kind="return"]');

          if (!phonePwa) {
            charts.forEach((chart) => chart.classList.remove("is-hidden"));
            buttons.forEach((button, index) => button.classList.toggle("is-active", index === 0));
            return;
          }

          charts.forEach((chart) => {
            chart.classList.toggle("is-hidden", chart.dataset.chartKind !== "value");
          });

          buttons.forEach((button) => {
            button.onclick = () => {
              const target = button.dataset.target;
              buttons.forEach((item) => item.classList.toggle("is-active", item === button));
              charts.forEach((chart) => {
                chart.classList.toggle("is-hidden", chart.dataset.chartKind !== target);
              });
              applyResponsiveCharts();
            };
          });
        });
      }

      function bindResponsiveCharts() {
        applyResponsiveCharts();
        initChartSwitchers();
        initPeriodSelects();
        window.addEventListener("resize", applyResponsiveCharts, { passive: true });
        window.addEventListener("resize", initChartSwitchers, { passive: true });
        window.addEventListener("resize", initPeriodSelects, { passive: true });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", bindResponsiveCharts);
      } else {
        bindResponsiveCharts();
      }
    })();
  </script>
</body>
</html>
