<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>股票庫存績效報表</title>
  <style>
    :root {
      --bg: #f0f0f0;
      --bg-2: #f7f7f7;
      --panel: rgba(250, 250, 250, 0.92);
      --panel-strong: rgba(255, 255, 255, 0.96);
      --line: rgba(82, 88, 98, 0.14);
      --line-strong: rgba(82, 88, 98, 0.24);
      --text: #475569;
      --heading: #111827;
      --muted: #64748b;
      --soft: #475569;
      --dim: #94a3b8;
      --accent: #2563eb;
      --accent-2: #f97316;
      --glow: rgba(37, 99, 235, 0.14);
      --shadow: 0 22px 52px rgba(82, 88, 98, 0.12);
      --red: #d83f56;
      --green: #0f9f72;
      --orange: #f97316;
    }
    * { box-sizing: border-box; }
    html { background: var(--bg); }
    body {
      margin: 0;
      color: var(--soft);
      font-family: "Consolas", "Microsoft JhengHei", "Segoe UI", sans-serif;
      font-size: 13px;
      background:
        radial-gradient(circle at top left, rgba(255, 255, 255, 0.72), transparent 28%),
        radial-gradient(circle at top right, rgba(31, 123, 216, 0.055), transparent 34%),
        linear-gradient(180deg, #f7f7f7 0%, var(--bg) 100%);
      min-height: 100vh;
    }
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(82, 88, 98, 0.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(82, 88, 98, 0.035) 1px, transparent 1px);
      background-size: 32px 32px;
      mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.58), transparent);
    }
    .shell {
      max-width: 1440px;
      margin: 0 auto;
      padding: 28px 20px 56px;
    }
    .hero,
    .panel,
    .card,
    .mini-stat {
      border: 1px solid var(--line);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, var(--panel) 100%);
      box-shadow: var(--shadow);
      backdrop-filter: blur(18px);
    }
    .eyebrow,
    .panel-kicker,
    .mini-label,
    .label,
    .table-caption {
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-size: 10px;
    }
    .eyebrow,
    .panel-kicker,
    .mini-label,
    .label,
    .table-caption,
    .muted {
      color: var(--dim);
    }
    .main {
      min-width: 0;
    }
    .hero {
      position: relative;
      overflow: hidden;
      border-radius: 0;
      padding: 20px 22px;
      margin-bottom: 20px;
    }
    .hero::after {
      content: "";
      position: absolute;
      inset: auto -20px -70px auto;
      width: 220px;
      height: 220px;
      border-radius: 0;
      background: radial-gradient(circle, rgba(31, 123, 216, 0.12), transparent 68%);
      filter: blur(14px);
    }
    .hero-grid {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: minmax(0, 1.6fr) minmax(280px, 0.8fr);
      gap: 18px;
      align-items: end;
    }
    .hero h1 {
      margin: 10px 0 10px;
      font-size: 22px;
      line-height: 1.08;
      letter-spacing: 0.02em;
      color: var(--accent);
    }
    .hero p {
      margin: 0;
      max-width: 720px;
      color: var(--dim);
      font-size: 13px;
      line-height: 1.6;
    }
    .hero-stats {
      display: grid;
      gap: 12px;
    }
    .mini-stat {
      border-radius: 0;
      padding: 12px 14px;
    }
    .mini-value {
      margin-top: 8px;
      font-size: 22px;
      font-weight: 700;
      color: var(--accent);
      text-shadow: 0 0 18px rgba(37, 99, 235, 0.16);
    }
    .mini-note {
      margin-top: 6px;
      color: var(--dim);
      font-size: 11px;
    }
    .section-title {
      margin: 0 0 14px;
      font-size: 18px;
      letter-spacing: 0.03em;
      color: var(--heading);
    }
    .stack {
      display: grid;
      gap: 18px;
    }
    .panel {
      border-radius: 0;
      padding: 18px;
      overflow: hidden;
    }
    .panel-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 16px;
    }
    .panel-head p {
      margin: 6px 0 0;
      color: var(--dim);
      font-size: 12px;
    }
    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 10px;
    }
    .currency-block + .currency-block {
      margin-top: 18px;
    }
    .market-label {
      display: inline-flex;
      margin-bottom: 12px;
      padding: 6px 10px;
      border: 1px solid var(--line-strong);
      background: rgba(37, 99, 235, 0.08);
      color: var(--accent);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .card {
      position: relative;
      overflow: hidden;
      border-radius: 0;
      padding: 12px 14px;
      min-height: 96px;
    }
    .card::after {
      content: "";
      position: absolute;
      inset: auto -24px -48px auto;
      width: 120px;
      height: 120px;
      border-radius: 0;
      background: radial-gradient(circle, rgba(255, 255, 255, 0.14), transparent 70%);
      filter: blur(10px);
    }
    .card.green {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(250, 250, 250, 0.95)),
        linear-gradient(135deg, rgba(15, 159, 114, 0.2), rgba(31, 123, 216, 0.1));
      border-color: rgba(15, 159, 114, 0.28);
      box-shadow: 0 16px 36px rgba(82, 88, 98, 0.1), inset 0 0 0 1px rgba(15, 159, 114, 0.08);
    }
    .card.red {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(250, 248, 249, 0.95)),
        linear-gradient(135deg, rgba(216, 63, 86, 0.18), rgba(249, 115, 22, 0.1));
      border-color: rgba(216, 63, 86, 0.28);
      box-shadow: 0 16px 36px rgba(82, 88, 98, 0.1), inset 0 0 0 1px rgba(216, 63, 86, 0.06);
    }
    .card.orange {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(251, 249, 245, 0.95)),
        linear-gradient(135deg, rgba(249, 115, 22, 0.18), rgba(37, 99, 235, 0.08));
      border-color: rgba(249, 115, 22, 0.28);
      box-shadow: 0 16px 36px rgba(82, 88, 98, 0.1), inset 0 0 0 1px rgba(249, 115, 22, 0.06);
    }
    .card .label {
      margin-bottom: 12px;
      color: var(--dim);
    }
    .card .value {
      position: relative;
      z-index: 1;
      font-size: 22px;
      line-height: 1.1;
      font-weight: 700;
      letter-spacing: -0.03em;
      color: var(--heading);
    }
    .card.green .value { color: #0f9f72; }
    .card.red .value { color: #bf3349; }
    .card.orange .value { color: #ea580c; }
    .table-shell {
      border-radius: 0;
      border: 1px solid var(--line);
      background: rgba(250, 250, 250, 0.88);
      overflow: auto;
    }
    .detail-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
    }
    .detail-table thead th {
      position: sticky;
      top: 0;
      z-index: 1;
      background: linear-gradient(180deg, rgba(238, 241, 245, 0.98), rgba(222, 227, 235, 0.98));
      color: var(--accent);
    }
    .detail-table th,
    .detail-table td {
      padding: 9px 9px;
      border-bottom: 1px solid var(--line);
      text-align: right;
      white-space: nowrap;
      color: var(--soft);
    }
    .detail-table tbody tr:nth-child(even) {
      background: rgba(82, 88, 98, 0.035);
    }
    .detail-table tbody tr:hover {
      background: rgba(31, 123, 216, 0.075);
    }
    .detail-table th:first-child,
    .detail-table td:first-child,
    .detail-table th:nth-child(2),
    .detail-table td:nth-child(2) {
      text-align: left;
      color: #1e293b;
    }
    .chart-block + .chart-block {
      margin-top: 26px;
      padding-top: 24px;
      border-top: 1px solid var(--line);
    }
    .chart-scroll {
      width: 100%;
      overflow-x: auto;
      overflow-y: hidden;
      margin-top: 12px;
      padding-bottom: 8px;
      -webkit-overflow-scrolling: touch;
    }
    .chart-scroll + .chart-scroll {
      margin-top: 18px;
    }
    .chart-scroll > div {
      min-width: 720px;
    }
    .plotly-graph-div {
      min-height: 440px;
    }
    @media (max-width: 1120px) {
    }
    @media (max-width: 840px) {
      .shell {
        padding: 16px 12px 36px;
      }
      .hero-grid {
        grid-template-columns: 1fr;
      }
      .hero h1 {
        font-size: 24px;
      }
      .card .value {
        font-size: 20px;
      }
      .chart-scroll > div {
        min-width: 680px;
      }
      .plotly-graph-div {
        min-height: 420px;
      }
    }
  </style>
</head>
<body>
  <div class="shell">
      <main class="main">
        <section class="hero">
          <div class="hero-grid">
            <div>
              <div class="eyebrow">Performance Overview</div>
              <h1>股票庫存績效報表</h1>
              <p>以明亮科技儀表板風格整理投資組合摘要、股票明細與互動式歷史績效圖，並保留你指定的市場配色規則、折線填色與 0% 穿越分段上色邏輯。</p>
            </div>
            <div class="hero-stats">
              <div class="mini-stat">
                <div class="mini-label">Report Scope</div>
                <div class="mini-value">TW / US</div>
                <div class="mini-note">支援台股與美股報酬邏輯</div>
              </div>
              <div class="mini-stat">
                <div class="mini-label">Visual Mode</div>
                <div class="mini-value">Light Console</div>
                <div class="mini-note">清爽、明亮、科技儀表板</div>
              </div>
            </div>
          </div>
        </section>

        <div class="stack">
          <section class="panel">
            <div class="panel-head">
              <div>
                <div class="panel-kicker">Portfolio Snapshot</div>
                <h2 class="section-title">投資組合總覽</h2>
              </div>
              <p>依市場規則呈現 KPI 卡片配色</p>
            </div>
            {% for group in summary_cards %}
            <div class="currency-block">
              <div class="market-label">{{ group.market_label }}</div>
              <div class="cards">
                {% for item in group.card_items %}
                <article class="card {{ item.tone }}">
                  <div class="label">{{ item.label }}</div>
                  <div class="value">{{ item.value }}</div>
                </article>
                {% endfor %}
              </div>
            </div>
            {% endfor %}
          </section>

          <section class="panel">
            <div class="panel-head">
              <div>
                <div class="panel-kicker">Holdings Table</div>
                <h2 class="section-title">股票明細</h2>
              </div>
              <p class="table-caption">即時成本 / 市值 / 總損益 / 總報酬率</p>
            </div>
            {% if table_html %}
            <div class="table-shell">
              {{ table_html | safe }}
            </div>
            {% else %}
            <p class="muted">目前沒有可顯示的股票明細。</p>
            {% endif %}
          </section>

          <section class="panel">
            <div class="panel-head">
              <div>
                <div class="panel-kicker">History & Return</div>
                <h2 class="section-title">歷史績效圖</h2>
              </div>
              <p>保留折線塗色、區間報酬率與分段上色邏輯</p>
            </div>
            {% for section in plot_sections %}
            <div class="chart-block">
              <div class="market-label">{{ section.market_label }}</div>
              <div class="chart-scroll">{{ section.value_chart | safe }}</div>
              <div class="chart-scroll">{{ section.return_chart | safe }}</div>
            </div>
            {% endfor %}
          </section>
        </div>
      </main>
  </div>
</body>
</html>
